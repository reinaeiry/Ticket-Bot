{
  "name": "reforgedz-ticket-bot",
  "version": "1.0.0",
  "description": "ReforgedZ ticket bot + transcript server",
  "main": "start.js",
  "scripts": {
    "setup": "npm install && npx prisma generate && npx prisma db push && npm run build",
    "build": "rimraf dist && tsc",
    "postinstall": "npx prisma generate && npm run build",
    "start": "node start.js",
    "start:bot": "node dist/index.js",
    "start:web": "node web/server.js"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@prisma/client": "^5.4.2",
    "axios": "^1.5.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "cookie-parser": "^1.4.6",
    "discord.js": "^14.13.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "jsonc": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "ticket-bot-transcript-uploader": "^1.4.2-hotfix"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.3",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.10.7",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^8.51.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.3",
    "prettier-eslint": "^16.3.0",
